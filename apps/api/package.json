{
  "name": "@csm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "node --watch --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "repair:schedules": "tsx src/cli/repair-schedules.ts",
    "verify:ledger": "tsx src/cli/verify-ledger.ts",
    "report:daily-recon": "tsx src/cli/daily-recon-report.ts"
  },
  "dependencies": {
    "@csm/bank-client": "workspace:*",
    "@csm/brokerage-client": "workspace:*",
    "@csm/contracts": "workspace:*",
    "@csm/database": "workspace:*",
    "@csm/domain": "workspace:*",
    "@csm/observability": "workspace:*",
    "@fastify/helmet": "13.0.1",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "9.5.1",
    "@fastify/swagger-ui": "5.2.3",
    "@temporalio/client": "1.11.8",
    "fastify": "5.4.0",
    "fastify-plugin": "5.0.1",
    "jose": "5.10.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
