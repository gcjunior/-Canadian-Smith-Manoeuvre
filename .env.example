# Copy to .env for local host runs. Docker Compose also consumes these values.
# Do not use these credentials outside local development.

NODE_ENV=development
LOG_LEVEL=info
SERVICE_VERSION=0.0.0

# Browser / host-machine URLs (localhost)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SHOW_RISK_DISCLOSURES=true
API_BASE_URL=http://localhost:3001
SESSION_COOKIE_NAME=csm_session
TEMPORAL_UI_BASE_URL=http://localhost:8233

# When processes run on the host (pnpm dev), use localhost.
# When processes run in Compose, override URLs to Docker service names (see compose file).
DATABASE_URL=postgresql://smith:smith@localhost:5432/smith_manoeuvre?schema=public
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=smith-manoeuvre

HOST=0.0.0.0
API_PORT=3001
BANK_SIMULATOR_PORT=3002
BROKERAGE_SIMULATOR_PORT=3003
WORKER_HEALTH_PORT=3100

BANK_SIMULATOR_BASE_URL=http://localhost:3002
BROKERAGE_SIMULATOR_BASE_URL=http://localhost:3003

DEFAULT_TIMEZONE=America/Toronto
PLATFORM_MONTHLY_DRAW_CAP_CENTS=500000
STARTUP_DEPENDENCY_TIMEOUT_MS=60000

# Local-only Postgres credentials (Compose)
POSTGRES_USER=smith
POSTGRES_PASSWORD=smith
POSTGRES_DB=smith_manoeuvre

# Required when NODE_ENV=production (Compose defaults). Never reuse outside local compose.
JWT_SIGNING_SECRET=compose-local-jwt-signing-secret-min-32b
WEBHOOK_SIGNING_SECRET=compose-local-webhook-signing-secret-32b

